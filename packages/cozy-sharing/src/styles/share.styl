@require 'components/forms.styl'
@require 'components/popover.styl'
@require 'settings/breakpoints.styl'

.share-byemail-onlybylink
    background var(--defaultBackgroundColor)
    padding 1rem 2rem
    margin -1.5rem -2rem 1rem

    +small-screen()
        padding 1rem
        margin -1.5rem -1rem 1rem

.share-modal-content
    @extend $form
    @extend $form-text
    @extend $form-button
    min-height: rem(250)

    .coz-form-group
        flex-shrink 0

.aligned-dropdown-button
  margin-right: -1rem

.coz-form-group
    margin 0

    h3
        margin .3rem 0 0

    h4
        margin 0 0 .3rem 0

    .coz-form
        margin 0

    .coz-form-desc
        color var(--secondaryTextColor)

input[type=text]
    width 100%

.share-details-created
.share-details-perm
    font-size            1rem
    margin               0.5rem 0 0.5rem 3.5rem
    padding-left         1.5rem
    background-position  0 center
    background-repeat    no-repeat

.share-details-created
    background-image     embedurl('../assets/icons/icon-calendar-16.svg')

.share-details-perm
    background-image     embedurl('../assets/icons/icon-pen-16.svg')
    margin-bottom .2rem

.share-details-perm-desc
    font-size     .875rem
    margin        0 0 0.5rem 3.5rem
    padding-left  1.5rem
    line-height   1.5
    color         var(--secondaryTextColor)
