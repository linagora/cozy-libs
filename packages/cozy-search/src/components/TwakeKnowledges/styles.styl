.source-panel
  margin 0
  border-radius 0
  display flex
  flex-direction column

.source-panel-header
  display flex
  justify-content space-between
  align-items center
  padding 16px 20px 0
  flex-shrink 0

.source-panel-description
  padding 16px 20px
  flex-shrink 0
  border-bottom 1px solid var(--dividerColor)

.source-panel-search
  padding 12px 20px
  flex-shrink 0

.source-panel-content
  flex 1
  overflow-y auto
  padding 0 8px

  &::-webkit-scrollbar
    width 6px

  &::-webkit-scrollbar-thumb
    background-color var(--dividerColor)
    border-radius 3px

.source-panel-footer
  padding 16px 20px
  border-top 1px solid var(--dividerColor)
  flex-shrink 0

.section-header
  display flex
  align-items center
  padding-right 8px !important
  gap 0 !important

.nested-item
  padding-left 5rem !important
  gap 0 !important

.drive-tree-item
  gap 0 !important

.clear-all-button
  margin-left auto !important
  color var(--secondaryTextColor) !important
  font-size 12px !important
  text-transform none !important
  min-width auto !important
  padding 0 !important
  height unset !important

  &:hover
    background-color transparent !important
    text-decoration underline !important

.date-label
  margin-left auto
  padding-left 1rem
  white-space nowrap

.mail-preview
  max-width 305px !important

.chat-header-actions
  display flex
  justify-content flex-end
  padding 0 16px

.header-clear-all
  text-transform none !important
  color var(--secondaryTextColor) !important

.knowledge-chips-icon
  height 16px
  width 16px
  margin 0 !important
